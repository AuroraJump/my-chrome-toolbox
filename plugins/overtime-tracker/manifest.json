{
  "manifest_version": 3,
  "name": "加班工时实时统计",
  "version": "2.2.4",
  "description": "在 hygon 考勤系统上按自定义规则实时统计加班工时",
  "icons": {
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "加班规则配置",
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
